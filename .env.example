# Aktuell validiert (siehe config/env.ts)
NODE_ENV=development
NEXT_PUBLIC_APP_URL=http://localhost:3000
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require
CLERK_SECRET_KEY=sk_test_...
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
OPENAI_API_KEY=sk-...
BLOB_READ_WRITE_TOKEN=vercel_blob_rw_...
RESEND_API_KEY=re_...
STRIPE_SECRET_KEY=sk_test_...

# Optional bis zum ersten Deploy bzw. bis `npm run stripe:setup-plans` gelaufen ist
# STRIPE_WEBHOOK_SECRET=
# STRIPE_PRICE_STARTER=
# STRIPE_PRICE_PRO=
# STRIPE_PRICE_BUSINESS=
# STRIPE_PRICE_ENTERPRISE=

# Optional bis der Webhook-Endpunkt in Clerk angelegt ist (braucht eine echte Deployment-URL)
